        super().__init__(application_id='com.blackonebc.GlavaControlCenter')
        self.glava_process = None
        self.ensure_config_exists()
        self.canvas_geo = {"x": 0, "y": 0, "width": 1920, "height": 1080}

    def ensure_config_exists(self, force=False):
        if force and os.path.exists(CONFIG_DIR):
            print("Setze Glava Konfigurationsverzeichnis zurück...")
            shutil.rmtree(CONFIG_DIR)
        
        if not os.path.exists(RC_FILE):
            print("Glava Konfiguration wird generiert...")
            if os.path.exists('/.flatpak-info'):
                subprocess.run(["flatpak-spawn", "--host", "glava", "--copy-config"], check=False)
            else:
                subprocess.run(["glava", "--copy-config"], check=False)

