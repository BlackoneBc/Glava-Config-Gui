    def load_canvas_geometry(self):
        """Berechnet die Bounding-Box (die Gesamtgröße) über alle Monitore hinweg."""
        display = Gdk.Display.get_default()
        monitors = display.get_monitors()
        
        if monitors.get_n_items() == 0:
            self.canvas_geo = {"x": 0, "y": 0, "width": 1920, "height": 1080}
            return
            
        min_x, min_y = float('inf'), float('inf')
        max_x, max_y = float('-inf'), float('-inf')
        
        for i in range(monitors.get_n_items()):
            monitor = monitors.get_item(i)
            geo = monitor.get_geometry()
            min_x = min(min_x, geo.x)
            min_y = min(min_y, geo.y)
            max_x = max(max_x, geo.x + geo.width)
            max_y = max(max_y, geo.y + geo.height)
            
        self.canvas_geo = {
            "x": int(min_x),
            "y": int(min_y),
            "width": int(max_x - min_x),
            "height": int(max_y - min_y)
        }

    def draw_preview_box(self, drawing_area, cr, width, height):
        cr.set_source_rgb(0.18, 0.18, 0.18) 
        cr.rectangle(10, 10, width - 20, height - 20)
        cr.fill()

        cr.set_source_rgb(0.35, 0.35, 0.35)
        cr.set_line_width(2)
        cr.rectangle(10, 10, width - 20, height - 20)
        cr.stroke()

        mon_x = self.canvas_geo["x"]
        mon_y = self.canvas_geo["y"]
        mon_w = self.canvas_geo["width"]
        mon_h = self.canvas_geo["height"]

        if mon_w == 0 or mon_h == 0:
            return

        scale_x = (width - 20) / mon_w
        scale_y = (height - 20) / mon_h

        gw = int(self.spin_width.get_value())
        gh = int(self.spin_height.get_value())
        gx = int(self.spin_x.get_value())
        gy = int(self.spin_y.get_value())

        rel_x = gx - mon_x
        rel_y = gy - mon_y

        box_x = 10 + (rel_x * scale_x)
        box_y = 10 + (rel_y * scale_y)
        box_w = gw * scale_x
        box_h = gh * scale_y

        box_x = max(10, min(box_x, width - 10))
        box_y = max(10, min(box_y, height - 10))
        box_w = min(box_w, width - 10 - box_x)
        box_h = min(box_h, height - 10 - box_y)

        if box_w > 0 and box_h > 0:
            cr.set_source_rgba(0.1, 0.45, 0.85, 0.55) 
            cr.rectangle(box_x, box_y, box_w, box_h)
            cr.fill()

            cr.set_source_rgb(0.2, 0.6, 1.0) 
            cr.set_line_width(1.5)
            cr.rectangle(box_x, box_y, box_w, box_h)
            cr.stroke()

    def on_geometry_changed(self, *args):
        self.preview_area.queue_draw()

    def on_autostart_toggled(self, switch, gparam):
        os.makedirs(os.path.dirname(AUTOSTART_FILE), exist_ok=True)
        if switch.get_active():
            if os.path.exists('/.flatpak-info'):
                exec_cmd = "flatpak run com.blackonebc.GlavaControlCenter"
            else:
                exec_cmd = "glava-config-gui"
                
            desktop_entry = f"[Desktop Entry]\nType=Application\nExec={exec_cmd}\nHidden=false\nNoDisplay=false\nX-GNOME-Autostart-enabled=true\nName=Glava\n"
            with open(AUTOSTART_FILE, "w") as f:
                f.write(desktop_entry)
        else:
            if os.path.exists(AUTOSTART_FILE):
                os.remove(AUTOSTART_FILE)

    def on_center_clicked(self, btn):
        # Zentriert Glava auf der gesamten Desktop-Leinwand
        w = int(self.spin_width.get_value())
        h = int(self.spin_height.get_value())
        
        x = self.canvas_geo["x"] + (self.canvas_geo["width"] // 2) - (w // 2)
        y = self.canvas_geo["y"] + (self.canvas_geo["height"] // 2) - (h // 2)
        
        self.spin_x.set_value(x)
        self.spin_y.set_value(y)
        self.preview_area.queue_draw()

    def on_reset_config_clicked(self, btn):
        self.ensure_config_exists(force=True)
        self.spin_width.set_value(600)
        self.spin_height.set_value(600)
        self.spin_x.set_value(0)
        self.spin_y.set_value(0)
        self.outline_switch.set_active(True)
        self.clickthrough_switch.set_active(True)
        self.background_switch.set_active(True)
        self.mode_combo.set_selected(0)
        self.vis_combo.set_selected(0)
        self.preview_area.queue_draw()
        print("Gesamte Konfiguration zurückgesetzt!")

    def on_reset_size_clicked(self, btn):
        self.spin_width.set_value(600)
        self.spin_height.set_value(600)
        self.preview_area.queue_draw()

    def on_reset_pos_clicked(self, btn):
        self.spin_x.set_value(0)
        self.spin_y.set_value(0)
        self.preview_area.queue_draw()

    def on_toggle_glava(self, btn):
        if btn.get_active():
            btn.set_label("Glava Stoppen")
            if os.path.exists('/.flatpak-info'):
                self.glava_process = subprocess.Popen(["flatpak-spawn", "--host", "glava"])
            else:
                self.glava_process = subprocess.Popen(["glava"])
        else:
            btn.set_label("Glava Starten")
            if self.glava_process:
                self.glava_process.terminate()
                self.glava_process = None
            
            if os.path.exists('/.flatpak-info'):
                subprocess.run(["flatpak-spawn", "--host", "killall", "-q", "glava"])
            else:
                subprocess.run(["killall", "-q", "glava"])

    def on_apply_clicked(self, btn):
        self.write_config()
        if self.toggle_btn.get_active():
            if os.path.exists('/.flatpak-info'):
                subprocess.run(["flatpak-spawn", "--host", "killall", "-q", "glava"])
                self.glava_process = subprocess.Popen(["flatpak-spawn", "--host", "glava"])
            else:
                subprocess.run(["killall", "-q", "glava"])
                self.glava_process = subprocess.Popen(["glava"])
        else:
            self.toggle_btn.set_active(True)

    def write_config(self):
        if not os.path.exists(RC_FILE):
            return

        w = int(self.spin_width.get_value())
        h = int(self.spin_height.get_value())
        x = int(self.spin_x.get_value())
        y = int(self.spin_y.get_value())
        
        modes = ["desktop", "normal", "!"]
        mode = modes[self.mode_combo.get_selected()]
        
        vis_types = ["radial", "graph", "wave", "circle", "bars"]
        vis = vis_types[self.vis_combo.get_selected()]

        clickthrough = "true" if self.clickthrough_switch.get_active() else "false"
        keep_below = self.background_switch.get_active()

        with open(RC_FILE, "r") as f:
            lines = f.readlines()

        new_lines = []
        for line in lines:
            sline = line.strip()
            if (sline.startswith("#request setgeometry") or 
                sline.startswith("#request setxwintype") or 
                sline.startswith("#request setclickthrough") or 
                sline.startswith("#request addxwinstate") or 
                sline.startswith("#request mod") or
                sline.startswith("// #request") or
                sline.startswith("/* #request")):
                continue
            new_lines.append(line)

        new_lines.append(f"\n#request setgeometry {x} {y} {w} {h}\n")
        new_lines.append(f'#request setxwintype "{mode}"\n')
        new_lines.append(f'#request setclickthrough {clickthrough}\n')
        
        if keep_below:
            new_lines.append('#request addxwinstate "below"\n')
            new_lines.append('#request addxwinstate "pinned"\n')
            new_lines.append('#request addxwinstate "skip_taskbar"\n')
            new_lines.append('#request addxwinstate "skip_pager"\n')
            
        new_lines.append(f"#request mod {vis}\n")

        with open(RC_FILE, "w") as f:
            f.writelines(new_lines)

        rgba = self.color_btn.get_rgba()
        hex_color = f"#{int(rgba.red*255):02x}{int(rgba.green*255):02x}{int(rgba.blue*255):02x}{int(rgba.alpha*255):02x}"
        outline_color = hex_color if self.outline_switch.get_active() else "#00000000"

        mod_file = os.path.join(CONFIG_DIR, f"{vis}.glsl")
        
        if os.path.exists(mod_file):
            with open(mod_file, "r") as f:
                mod_lines = f.readlines()
            
            new_mod_lines = []
            color_keys = ["#define COLOR", "#define BG_COLOR", "#define FG_COLOR", "#define BAR_COLOR"]
            found_keys = set()
            outline_replaced = False

            for line in mod_lines:
                sline = line.strip()
                replaced = False
                
                for key in color_keys:
                    if sline.startswith(key):
                        new_mod_lines.append(f'{key} {hex_color}\n')
                        found_keys.add(key)
                        replaced = True
                        break
                
                if not replaced and sline.startswith("#define OUTLINE"):
                    new_mod_lines.append(f'#define OUTLINE {outline_color}\n')
                    outline_replaced = True
                    replaced = True

                if not replaced:
                    new_mod_lines.append(line)
            
            if "#define COLOR" not in found_keys:
                new_mod_lines.append(f'\n#define COLOR {hex_color}\n')
            if not outline_replaced:
                new_mod_lines.append(f'#define OUTLINE {outline_color}\n')

            with open(mod_file, "w") as f:
                f.writelines(new_mod_lines)

if __name__ == '__main__':
    app = GlavaConfigurator()
    app.run(None)
