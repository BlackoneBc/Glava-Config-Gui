#!/usr/bin/env python3
import gi
import os
import subprocess
import shutil

# GTK4 und Libadwaita initialisieren
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, Gio, GLib, Gdk

if os.path.exists('/.flatpak-info'):
    USER_HOME = os.path.expanduser("~")
    CONFIG_DIR = os.path.join(USER_HOME, ".config/glava")
    AUTOSTART_FILE = os.path.join(USER_HOME, ".config/autostart/glava.desktop")
else:
    CONFIG_DIR = os.path.expanduser("~/.config/glava")
    AUTOSTART_FILE = os.path.expanduser("~/.config/autostart/glava.desktop")

RC_FILE = os.path.join(CONFIG_DIR, "rc.glsl")

class GlavaConfigurator(Adw.Application):
    def __init__(self):
        super().__init__(application_id='com.blackonebc.GlavaControlCenter')
        self.glava_process = None
        self.ensure_config_exists()
        
        # Geometrie-Speicher
        self.monitors_data = []
        self.canvas_geo = {"x": 0, "y": 0, "width": 1920, "height": 1080}
        
        # Drag-Status
        self.drag_start_gx = 0
        self.drag_start_gy = 0
        self.is_dragging_box = False

    def ensure_config_exists(self, force=False):
        if force and os.path.exists(CONFIG_DIR):
            print("Setze Glava Konfigurationsverzeichnis zurück...")
            shutil.rmtree(CONFIG_DIR)
        
        if not os.path.exists(RC_FILE):
            print("Glava Konfiguration wird generiert...")
            if os.path.exists('/.flatpak-info'):
                subprocess.run(["flatpak-spawn", "--host", "glava", "--copy-config"], check=False)
            else:
                subprocess.run(["glava", "--copy-config"], check=False)

    def do_activate(self):
        style_manager = Adw.StyleManager.get_default()
        style_manager.set_color_scheme(Adw.ColorScheme.FORCE_DARK)

        window = Adw.ApplicationWindow(application=self)
        window.set_title("Glava Control Center")
        window.set_default_size(650, 950)

        self.load_canvas_geometry()

        header = Adw.HeaderBar()
        
        self.toggle_btn = Gtk.ToggleButton(label="Glava Starten")
        self.toggle_btn.connect("toggled", self.on_toggle_glava)
        header.pack_start(self.toggle_btn)

        apply_btn = Gtk.Button(label="Anwenden")
        apply_btn.add_css_class("suggested-action")
        apply_btn.connect("clicked", self.on_apply_clicked)
        header.pack_end(apply_btn)

        scrolled_window = Gtk.ScrolledWindow()
        scrolled_window.set_vexpand(True)
        scrolled_window.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=24)
        main_box.set_margin_top(24)
        main_box.set_margin_bottom(24)
        main_box.set_margin_start(32)
        main_box.set_margin_end(32)

        # === GRUPPE 1: ALLGEMEIN ===
        group_general = Adw.PreferencesGroup(title="Allgemein")
        main_box.append(group_general)

        self.autostart_switch = Gtk.Switch()
        self.autostart_switch.set_active(os.path.exists(AUTOSTART_FILE))
        self.autostart_switch.set_valign(Gtk.Align.CENTER)
        self.autostart_switch.connect("notify::active", self.on_autostart_toggled)
        row_autostart = Adw.ActionRow(title="Autostart beim Login")
        row_autostart.add_suffix(self.autostart_switch)
        group_general.add(row_autostart)

        self.clickthrough_switch = Gtk.Switch()
        self.clickthrough_switch.set_active(True)
        self.clickthrough_switch.set_valign(Gtk.Align.CENTER)
        row_clickthrough = Adw.ActionRow(title="Durchklickbar (Mausklicks ignorieren)")
        row_clickthrough.add_suffix(self.clickthrough_switch)
        group_general.add(row_clickthrough)

        self.background_switch = Gtk.Switch()
        self.background_switch.set_active(True)
        self.background_switch.set_valign(Gtk.Align.CENTER)
        row_background = Adw.ActionRow(title="Im Hintergrund halten (Hinter Fenstern)")
        row_background.add_suffix(self.background_switch)
        group_general.add(row_background)

        window_modes = Gtk.StringList.new(["desktop", "normal", "!"])
        self.mode_combo = Adw.ComboRow(title="Fenster Desktop-Modus", model=window_modes)
        group_general.add(self.mode_combo)

        # === GRUPPE 2: GEOMETRIE & TYP ===
        group_geo = Adw.PreferencesGroup(title="Visualizer & Position")
        main_box.append(group_geo)

        vis_types = Gtk.StringList.new(["radial", "graph", "wave", "circle", "bars"])
        self.vis_combo = Adw.ComboRow(title="Visualizer Typ", model=vis_types)
        group_geo.add(self.vis_combo)

        self.spin_width = Gtk.SpinButton.new_with_range(100, 5000, 10)
        self.spin_width.set_value(600)
        self.spin_width.set_valign(Gtk.Align.CENTER)
        self.spin_width.connect("value-changed", self.on_geometry_changed)
        row_width = Adw.ActionRow(title="Breite (px)")
        row_width.add_suffix(self.spin_width)
        group_geo.add(row_width)

        self.spin_height = Gtk.SpinButton.new_with_range(100, 5000, 10)
        self.spin_height.set_value(600)
        self.spin_height.set_valign(Gtk.Align.CENTER)
        self.spin_height.connect("value-changed", self.on_geometry_changed)
        row_height = Adw.ActionRow(title="Höhe (px)")
        row_height.add_suffix(self.spin_height)
        group_geo.add(row_height)

        self.spin_x = Gtk.SpinButton.new_with_range(-10000, 10000, 1)
        self.spin_x.set_valign(Gtk.Align.CENTER)
        self.spin_x.connect("value-changed", self.on_geometry_changed)
        row_x = Adw.ActionRow(title="X Position (Links/Rechts)")
        row_x.add_suffix(self.spin_x)
        group_geo.add(row_x)

        self.spin_y = Gtk.SpinButton.new_with_range(-10000, 10000, 1)
        self.spin_y.set_valign(Gtk.Align.CENTER)
        self.spin_y.connect("value-changed", self.on_geometry_changed)
        row_y = Adw.ActionRow(title="Y Position (Oben/Unten)")
        row_y.add_suffix(self.spin_y)
        group_geo.add(row_y)

        # Menü-Button zum Zentrieren auf spezifischen Monitoren
        self.center_menu_btn = Gtk.MenuButton(label="Monitor auswählen...")
        self.center_menu_btn.set_valign(Gtk.Align.CENTER)
        self.build_center_popover()
        
        row_center = Adw.ActionRow(title="In der Mitte platzieren auf:")
        row_center.add_suffix(self.center_menu_btn)
        group_geo.add(row_center)

        # === GRUPPE 3: FARBEN & OUTLINES ===
        group_color = Adw.PreferencesGroup(title="Farben & Effekte")
        main_box.append(group_color)

        self.color_dialog = Gtk.ColorDialog()
        self.color_btn = Gtk.ColorDialogButton(dialog=self.color_dialog)
        self.color_btn.set_valign(Gtk.Align.CENTER)
        row_color = Adw.ActionRow(title="Hauptfarbe & Deckkraft")
        row_color.add_suffix(self.color_btn)
        group_color.add(row_color)

        self.outline_switch = Gtk.Switch()
        self.outline_switch.set_active(True)
        self.outline_switch.set_valign(Gtk.Align.CENTER)
        row_outline = Adw.ActionRow(title="Outlines (Ränder hervorheben)")
        row_outline.add_suffix(self.outline_switch)
        group_color.add(row_outline)

        # === GRUPPE 4: LIVE VORSCHAU ===
        group_preview = Adw.PreferencesGroup(title="Leinwand Vorschau")
        main_box.append(group_preview)
        
        self.preview_area = Gtk.DrawingArea()
        self.preview_area.set_content_width(450)
        self.preview_area.set_content_height(280)
        self.preview_area.set_draw_func(self.draw_preview_box)
        
        self.drag_gesture = Gtk.GestureDrag.new()
        self.drag_gesture.connect("drag-begin", self.on_drag_begin)
        self.drag_gesture.connect("drag-update", self.on_drag_update)
        self.preview_area.add_controller(self.drag_gesture)
        
        # Geändert von "Vorschau (Alle Monitore, ziehbar)" zu "Vorschau"
        row_preview = Adw.ActionRow(title="Vorschau")
        row_preview.add_suffix(self.preview_area)
        group_preview.add(row_preview)

        # === GRUPPE 5: RESET BUTTONS ===
        group_resets = Adw.PreferencesGroup()
        main_box.append(group_resets)

        reset_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        reset_box.set_homogeneous(True)
        reset_box.set_valign(Gtk.Align.CENTER)

        btn_reset_config = Gtk.Button(label="Config zurücksetzen")
        btn_reset_config.add_css_class("destructive-action")
        btn_reset_config.set_valign(Gtk.Align.CENTER)
        btn_reset_config.connect("clicked", self.on_reset_config_clicked)

        btn_reset_size = Gtk.Button(label="Größe zurücksetzen")
        btn_reset_size.set_valign(Gtk.Align.CENTER)
        btn_reset_size.connect("clicked", self.on_reset_size_clicked)

        btn_reset_pos = Gtk.Button(label="Position zurücksetzen")
        btn_reset_pos.set_valign(Gtk.Align.CENTER)
        btn_reset_pos.connect("clicked", self.on_reset_pos_clicked)

        reset_box.append(btn_reset_config)
        reset_box.append(btn_reset_size)
        reset_box.append(btn_reset_pos)

        group_resets.add(reset_box)

        scrolled_window.set_child(main_box)

        toolbar_view = Adw.ToolbarView()
        toolbar_view.add_top_bar(header)
        toolbar_view.set_content(scrolled_window)
        
        window.set_content(toolbar_view)
        window.present()

        self.load_config()

