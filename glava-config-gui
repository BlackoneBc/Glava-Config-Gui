if os.path.exists('/.flatpak-info'):
    USER_HOME = os.path.expanduser("~")
    CONFIG_DIR = os.path.join(USER_HOME, ".config/glava")
    AUTOSTART_FILE = os.path.join(USER_HOME, ".config/autostart/glava.desktop")
else:
    CONFIG_DIR = os.path.expanduser("~/.config/glava")
    AUTOSTART_FILE = os.path.expanduser("~/.config/autostart/glava.desktop")

RC_FILE = os.path.join(CONFIG_DIR, "rc.glsl")

