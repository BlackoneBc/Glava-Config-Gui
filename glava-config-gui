    def on_vis_type_changed(self, combo, param):
        vis_types = ["radial", "graph", "wave", "circle", "bars"]
        idx = combo.get_selected()
        if 0 <= idx < len(vis_types):
            self.current_vis = vis_types[idx]
            self.reload_type_settings()

    def reload_type_settings(self):
        main_box = self.group_type_settings.get_parent()
        if main_box:
            main_box.remove(self.group_type_settings)

        self.group_type_settings = Adw.PreferencesGroup(title="Einstellungen für diesen Typ")
        main_box.insert_child_after(self.group_type_settings, self.vis_type_group)

        self.type_widgets = {}
        filepath = os.path.join(CONFIG_DIR, f"{self.current_vis}.glsl")
        defines = self.parse_glsl_defines(filepath)
        for d in defines:
            name = d['name']
            typ = d['type']
            row = Adw.ActionRow(title=name)
            
            if typ == 'color':
                color_btn = Gtk.ColorDialogButton(dialog=Gtk.ColorDialog())
                rgba = self._hex_to_rgba(d['value'])
                if rgba:
                    color_btn.set_rgba(rgba)
                color_btn.set_valign(Gtk.Align.CENTER)
                row.add_suffix(color_btn)
                self.type_widgets[name] = color_btn
            elif typ == 'float':
                try:
                    val = float(d['value'].rstrip('f'))
                except ValueError:
                    val = 1.0
                spin = Gtk.SpinButton.new_with_range(-1000.0, 1000.0, 0.01)
                spin.set_value(val)
                spin.set_digits(4)
                spin.set_valign(Gtk.Align.CENTER)
                row.add_suffix(spin)
                self.type_widgets[name] = spin
            elif typ == 'bool':
                switch = Gtk.Switch()
                switch.set_active(d['value'].lower() in ('true', '1'))
                switch.set_valign(Gtk.Align.CENTER)
                row.add_suffix(switch)
                self.type_widgets[name] = switch
            else:
                label = Gtk.Label(label=d['value'])
                label.set_valign(Gtk.Align.CENTER)
                row.add_suffix(label)
                self.type_widgets[name] = None

            self.group_type_settings.add(row)

    def parse_glsl_defines(self, filepath):
        defines = []
        if not os.path.exists(filepath):
            return defines
        with open(filepath, 'r') as f:
            for line in f:
                sline = line.strip()
                if not sline.startswith('#define'):
                    continue
                comment_pos = sline.find('//')
                if comment_pos != -1:
                    sline = sline[:comment_pos].strip()
                parts = sline.split()
                if len(parts) < 3:
                    continue
                name = parts[1]
                value = parts[2]
                typ = self._guess_define_type(value)
                defines.append({'name': name, 'value': value, 'type': typ})
        return defines

    def _guess_define_type(self, value):
        if value.startswith('#'):
            hex_part = value[1:]
            if len(hex_part) in (6, 8) and all(c in '0123456789abcdefABCDEF' for c in hex_part):
                return 'color'
        if value.lower() in ('true', 'false'):
            return 'bool'
        try:
            float(value.rstrip('f'))
            return 'float'
        except ValueError:
            pass
        return 'string'

    def _rgba_to_hex(self, rgba):
        return f"#{int(rgba.red*255):02x}{int(rgba.green*255):02x}{int(rgba.blue*255):02x}{int(rgba.alpha*255):02x}"

    def load_config(self):
        if not os.path.exists(RC_FILE):
            self.current_vis = "radial"
            self.vis_combo.set_selected(0)
            self.reload_type_settings()
            return

        with open(RC_FILE, "r") as f:
            lines = f.readlines()

        for line in lines:
            s = line.strip()

            if s.startswith("#request setgeometry"):
                parts = s.split()
                if len(parts) == 6:
                    self.spin_x.set_value(int(parts[2]))
                    self.spin_y.set_value(int(parts[3]))
                    self.spin_width.set_value(int(parts[4]))
                    self.spin_height.set_value(int(parts[5]))

            elif s.startswith("#request setxwintype"):
                val = s.split('"')[1] if '"' in s else "desktop"
                modes = ["desktop", "normal", "!"]
                if val in modes:
                    self.mode_combo.set_selected(modes.index(val))

            elif s.startswith("#request setclickthrough"):
                parts = s.split()
                if len(parts) == 3:
                    self.clickthrough_switch.set_active(parts[2] == "true")

            elif s.startswith('#request addxwinstate "below"'):
                self.background_switch.set_active(True)

            elif s.startswith("#request mod"):
                parts = s.split()
                if len(parts) == 3:
                    self.current_vis = parts[2]
                    vis_types = ["radial", "graph", "wave", "circle", "bars"]
                    if self.current_vis in vis_types:
                        self.vis_combo.set_selected(vis_types.index(self.current_vis))

        self.reload_type_settings()
        self.preview_area.queue_draw()

    def write_config(self):
        if not os.path.exists(RC_FILE):
            return

        w = int(self.spin_width.get_value())
        h = int(self.spin_height.get_value())
        x = int(self.spin_x.get_value())
        y = int(self.spin_y.get_value())

        modes = ["desktop", "normal", "!"]
        mode = modes[self.mode_combo.get_selected()]

        clickthrough = "true" if self.clickthrough_switch.get_active() else "false"
        keep_below = self.background_switch.get_active()

        with open(RC_FILE, "r") as f:
            lines = f.readlines()

        new_lines = []
        for line in lines:
            sline = line.strip()
            if (sline.startswith("#request setgeometry") or
                sline.startswith("#request setxwintype") or
                sline.startswith("#request setclickthrough") or
                sline.startswith("#request addxwinstate") or
                sline.startswith("#request mod") or
                sline.startswith("// #request") or
                sline.startswith("/* #request")):
                continue
            new_lines.append(line)

        new_lines.append(f"\n#request setgeometry {x} {y} {w} {h}\n")
        new_lines.append(f'#request setxwintype "{mode}"\n')
        new_lines.append(f'#request setclickthrough {clickthrough}\n')

        if keep_below:
            new_lines.append('#request addxwinstate "below"\n')
            new_lines.append('#request addxwinstate "pinned"\n')
            new_lines.append('#request addxwinstate "skip_taskbar"\n')
            new_lines.append('#request addxwinstate "skip_pager"\n')

        new_lines.append(f"#request mod {self.current_vis}\n")

        with open(RC_FILE, "w") as f:
            f.writelines(new_lines)

        filepath = os.path.join(CONFIG_DIR, f"{self.current_vis}.glsl")
        if os.path.exists(filepath):
            with open(filepath, 'r') as f:
                mod_lines = f.readlines()

            new_mod_lines = []
            defines_written = set()
            for line in mod_lines:
                sline = line.strip()
                if sline.startswith('#define'):
                    parts = sline.split()
                    if len(parts) >= 3:
                        name = parts[1]
                        if name in self.type_widgets:
                            widget = self.type_widgets[name]
                            if isinstance(widget, Gtk.ColorDialogButton):
                                rgba = widget.get_rgba()
                                hex_color = self._rgba_to_hex(rgba)
                                new_mod_lines.append(f"#define {name} {hex_color}\n")
                            elif isinstance(widget, Gtk.SpinButton):
                                val = widget.get_value()
                                new_mod_lines.append(f"#define {name} {val:.4f}\n")
                            elif isinstance(widget, Gtk.Switch):
                                state = "true" if widget.get_active() else "false"
                                new_mod_lines.append(f"#define {name} {state}\n")
                            else:
                                new_mod_lines.append(line)
                            defines_written.add(name)
                            continue
                new_mod_lines.append(line)

            for name, widget in self.type_widgets.items():
                if name not in defines_written:
                    if isinstance(widget, Gtk.ColorDialogButton):
                        rgba = widget.get_rgba()
                        hex_color = self._rgba_to_hex(rgba)
                        new_mod_lines.append(f"#define {name} {hex_color}\n")
                    elif isinstance(widget, Gtk.SpinButton):
                        val = widget.get_value()
                        new_mod_lines.append(f"#define {name} {val:.4f}\n")
                    elif isinstance(widget, Gtk.Switch):
                        state = "true" if widget.get_active() else "false"
                        new_mod_lines.append(f"#define {name} {state}\n")

            with open(filepath, 'w') as f:
                f.writelines(new_mod_lines)

    def _hex_to_rgba(self, hex_str):
        if "/*" in hex_str: hex_str = hex_str.split("/*")[0].strip()
        if "//" in hex_str: hex_str = hex_str.split("//")[0].strip()
        hex_str = hex_str.lstrip("#")
        try:
            if len(hex_str) == 8:
                r, g, b, a = (int(hex_str[i:i+2], 16) / 255.0 for i in (0, 2, 4, 6))
            elif len(hex_str) == 6:
                r, g, b = (int(hex_str[i:i+2], 16) / 255.0 for i in (0, 2, 4))
                a = 1.0
            else:
                return None
            rgba = Gdk.RGBA()
            rgba.red, rgba.green, rgba.blue, rgba.alpha = r, g, b, a
            return rgba
        except ValueError:
            return None

    def load_canvas_geometry(self):
        display = Gdk.Display.get_default()
        monitors = display.get_monitors()
        
        self.monitors_data = []
        
        if monitors.get_n_items() == 0:
            self.canvas_geo = {"x": 0, "y": 0, "width": 1920, "height": 1080}
            return
            
        min_x, min_y = float('inf'), float('inf')
        max_x, max_y = float('-inf'), float('-inf')
        
        for i in range(monitors.get_n_items()):
            monitor = monitors.get_item(i)
            geo = monitor.get_geometry()
            
            model_name = monitor.get_model()
            manufacturer = monitor.get_manufacturer()
            connector = monitor.get_connector()
            
            name_parts = []
            if manufacturer: name_parts.append(manufacturer)
            if model_name: name_parts.append(model_name)
            
            full_title = " ".join(name_parts)
            if not full_title and connector:
                full_title = f"Anschluss {connector}"
            if not full_title:
                full_title = f"Monitor {i + 1}"
                
            is_main = (geo.x == 0 and geo.y == 0)
            
            self.monitors_data.append({
                "x": geo.x,
                "y": geo.y,
                "width": geo.width,
                "height": geo.height,
                "title": full_title,
                "is_main": is_main
            })
                
            min_x = min(min_x, geo.x)
            min_y = min(min_y, geo.y)
            max_x = max(max_x, geo.x + geo.width)
            max_y = max(max_y, geo.y + geo.height)
            
        self.canvas_geo = {
            "x": int(min_x),
            "y": int(min_y),
            "width": int(max_x - min_x),
            "height": int(max_y - min_y)
        }

    def build_center_popover(self):
        popover = Gtk.Popover()
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        box.set_margin_top(6)
        box.set_margin_bottom(6)
        box.set_margin_start(6)
        box.set_margin_end(6)

        for i, m in enumerate(self.monitors_data):
            btn_label = f"{m['title']} ({m['width']}x{m['height']})"
            if m['is_main']:
                btn_label += " [Hauptbildschirm]"
                
            btn = Gtk.Button(label=btn_label)
            btn.connect("clicked", lambda b, index=i: self.center_on_specific_monitor(index, popover))
            box.append(btn)

        popover.set_child(box)
        self.center_menu_btn.set_popover(popover)

    def center_on_specific_monitor(self, idx, popover):
        popover.popdown()
        m = self.monitors_data[idx]
        
        w = int(self.spin_width.get_value())
        h = int(self.spin_height.get_value())
        
        x = m["x"] + (m["width"] // 2) - (w // 2)
        y = m["y"] + (m["height"] // 2) - (h // 2)
        
        self.spin_x.set_value(x)
        self.spin_y.set_value(y)

    def draw_preview_box(self, drawing_area, cr, width, height):
        cr.set_source_rgb(0.12, 0.12, 0.12)
        cr.paint()

        canvas_w = self.canvas_geo["width"]
        canvas_h = self.canvas_geo["height"]

        if canvas_w == 0 or canvas_h == 0:
            return

        scale = min((width - 20) / canvas_w, (height - 20) / canvas_h)
        offset_x = (width - (canvas_w * scale)) / 2
        offset_y = (height - (canvas_h * scale)) / 2

        for m in self.monitors_data:
            mx = offset_x + (m["x"] - self.canvas_geo["x"]) * scale
            my = offset_y + (m["y"] - self.canvas_geo["y"]) * scale
            mw = m["width"] * scale
            mh = m["height"] * scale

            cr.set_source_rgb(0.25, 0.25, 0.25)
            cr.rectangle(mx, my, mw, mh)
            cr.fill()

            cr.set_source_rgb(0.4, 0.4, 0.4)
            cr.set_line_width(1.5)
            cr.rectangle(mx, my, mw, mh)
            cr.stroke()

        gw = int(self.spin_width.get_value())
        gh = int(self.spin_height.get_value())
        gx = int(self.spin_x.get_value())
        gy = int(self.spin_y.get_value())

        bx = offset_x + (gx - self.canvas_geo["x"]) * scale
        by = offset_y + (gy - self.canvas_geo["y"]) * scale
        bw = gw * scale
        bh = gh * scale

        if bw > 0 and bh > 0:
            cr.set_source_rgba(0.1, 0.45, 0.85, 0.55)
            cr.rectangle(bx, by, bw, bh)
            cr.fill()

            cr.set_source_rgb(0.2, 0.6, 1.0)
            cr.set_line_width(1.5)
            cr.rectangle(bx, by, bw, bh)
            cr.stroke()

    def on_drag_begin(self, gesture, start_x, start_y):
        w = self.preview_area.get_width()
        h = self.preview_area.get_height()
        canvas_w = self.canvas_geo["width"]
        canvas_h = self.canvas_geo["height"]

        if canvas_w == 0 or canvas_h == 0:
            self.is_dragging_box = False
            return

        scale = min((w - 20) / canvas_w, (h - 20) / canvas_h)
        offset_x = (w - (canvas_w * scale)) / 2
        offset_y = (h - (canvas_h * scale)) / 2

        gw = int(self.spin_width.get_value())
        gh = int(self.spin_height.get_value())
        gx = int(self.spin_x.get_value())
        gy = int(self.spin_y.get_value())

        bx = offset_x + (gx - self.canvas_geo["x"]) * scale
        by = offset_y + (gy - self.canvas_geo["y"]) * scale
        bw = gw * scale
        bh = gh * scale

        if bx <= start_x <= (bx + bw) and by <= start_y <= (by + bh):
            self.is_dragging_box = True
            self.drag_start_gx = gx
            self.drag_start_gy = gy
        else:
            self.is_dragging_box = False

    def on_drag_update(self, gesture, offset_x, offset_y):
        if not self.is_dragging_box:
            return

        w = self.preview_area.get_width()
        h = self.preview_area.get_height()
        canvas_w = self.canvas_geo["width"]
        canvas_h = self.canvas_geo["height"]

        scale = min((w - 20) / canvas_w, (h - 20) / canvas_h)
        
        if scale > 0:
            new_x = self.drag_start_gx + (offset_x / scale)
            new_y = self.drag_start_gy + (offset_y / scale)
            
            gw = int(self.spin_width.get_value())
            gh = int(self.spin_height.get_value())

            min_allowed_x = self.canvas_geo["x"]
            max_allowed_x = self.canvas_geo["x"] + self.canvas_geo["width"] - gw
            min_allowed_y = self.canvas_geo["y"]
            max_allowed_y = self.canvas_geo["y"] + self.canvas_geo["height"] - gh

            new_x = max(min_allowed_x, min(new_x, max_allowed_x))
            new_y = max(min_allowed_y, min(new_y, max_allowed_y))
            
            self.spin_x.handler_block_by_func(self.on_geometry_changed)
            self.spin_y.handler_block_by_func(self.on_geometry_changed)
            
            self.spin_x.set_value(int(new_x))
            self.spin_y.set_value(int(new_y))
            
            self.spin_x.handler_unblock_by_func(self.on_geometry_changed)
            self.spin_y.handler_unblock_by_func(self.on_geometry_changed)
            
            self.preview_area.queue_draw()

    def on_geometry_changed(self, *args):
        self.preview_area.queue_draw()

    def on_autostart_toggled(self, switch, gparam):
        os.makedirs(os.path.dirname(AUTOSTART_FILE), exist_ok=True)
        if switch.get_active():
            exec_cmd = "flatpak run com.blackonebc.GlavaControlCenter" if os.path.exists('/.flatpak-info') else "glava"
            desktop_entry = (
                "[Desktop Entry]\nType=Application\n"
                f"Exec={exec_cmd}\nHidden=false\nNoDisplay=false\n"
                "X-GNOME-Autostart-enabled=true\nName=Glava\n"
            )
            with open(AUTOSTART_FILE, "w") as f:
                f.write(desktop_entry)
        else:
            if os.path.exists(AUTOSTART_FILE):
                os.remove(AUTOSTART_FILE)

    def on_reset_config_clicked(self, btn):
        self.ensure_config_exists(force=True)
        self.spin_width.set_value(600)
        self.spin_height.set_value(600)
        self.spin_x.set_value(0)
        self.spin_y.set_value(0)
        self.clickthrough_switch.set_active(True)
        self.background_switch.set_active(True)
        self.mode_combo.set_selected(0)
        self.vis_combo.set_selected(0)
        self.current_vis = "radial"
        self.reload_type_settings()
        self.preview_area.queue_draw()
        print("Gesamte Konfiguration zurückgesetzt!")

    def on_reset_size_clicked(self, btn):
        self.spin_width.set_value(600)
        self.spin_height.set_value(600)

    def on_reset_pos_clicked(self, btn):
        self.spin_x.set_value(0)
        self.spin_y.set_value(0)

    def on_toggle_glava(self, btn):
        if btn.get_active():
            btn.set_label("Glava stoppen")
            if os.path.exists('/.flatpak-info'):
                self.glava_process = subprocess.Popen(["flatpak-spawn", "--host", "glava"])
            else:
                self.glava_process = subprocess.Popen(["glava"])
        else:
            btn.set_label("Glava starten")
            if self.glava_process:
                self.glava_process.terminate()
                self.glava_process = None
            if os.path.exists('/.flatpak-info'):
                subprocess.run(["flatpak-spawn", "--host", "killall", "-q", "glava"])
            else:
                subprocess.run(["killall", "-q", "glava"])

    def on_apply_clicked(self, btn):
        self.write_config()
        if self.toggle_btn.get_active():
            if os.path.exists('/.flatpak-info'):
                subprocess.run(["flatpak-spawn", "--host", "killall", "-q", "glava"])
                self.glava_process = subprocess.Popen(["flatpak-spawn", "--host", "glava"])
            else:
                subprocess.run(["killall", "-q", "glava"])
                self.glava_process = subprocess.Popen(["glava"])
        else:
            self.toggle_btn.set_active(True)

